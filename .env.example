# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# App
LOG_LEVEL=INFO
AGUI_TIMEOUT_SECONDS=300
ENVIRONMENT=development

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# RL
RL_ALPHA=0.1
RL_GAMMA=0.9
