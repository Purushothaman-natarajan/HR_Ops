# Langfuse Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Application
LOG_LEVEL=INFO
AGUI_TIMEOUT_SECONDS=300
ENVIRONMENT=development
APP_ROLE=admin

# ChromaDB
CHROMA_PERSIST_DIR=./backend/data/chroma_db

# RL Parameters
RL_ALPHA=0.1
RL_GAMMA=0.9

# Database (change DATABASE_URL to swap SQLite ↔ PostgreSQL ↔ MySQL)
DATABASE_URL=sqlite:///./backend/data/hr_ops.db

# Auth
AUTH_SECRET_KEY=change-me-in-production
